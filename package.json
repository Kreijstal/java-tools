{
  "name": "jvm_tools",
  "version": "0.0.1",
  "main": "index.js",
  "scripts": {
    "test": "node scripts/run-tests.js",
    "test:specific": "node scripts/run-tests.js",
    "test:playwright": "playwright test",
    "benchmark:awt:firefox": "node scripts/benchmarkAwtHotLoopFirefox.js",
    "benchmark:canvas:firefox": "node scripts/benchmarkFirefoxCanvas.js",
    "benchmark:jit:fields": "node scripts/benchmarkJitFieldSites.js",
    "benchmark:jvm:intermethod": "node scripts/benchmarkIntermethodCalls.js",
    "benchmark:jvm:dekobloko-hot-loops": "node scripts/benchmarkDekoblokoHotLoops.js",
    "benchmark:jvm:dekobloko-renderer-traffic": "node scripts/benchmarkDekoblokoRendererTraffic.js",
    "benchmark:jvm:dekobloko-trace-replay": "node scripts/benchmarkDekoblokoTraceReplay.js",
    "benchmark:jvm:dekobloko-regions": "node scripts/benchmarkDekoblokoRegionSuite.js",
    "trace:dekobloko:derive-region": "node scripts/deriveDekoblokoRegionTrace.js",
    "profile:dekobloko:firefox": "node scripts/profileDekoblokoFirefox.js",
    "analyze:dekobloko:firefox-profile": "node scripts/analyzeFirefoxProfile.js",
    "test:fused-renderers": "node scripts/differentialFusedRenderers.js",
    "test:all": "npm test && npm run test:playwright",
    "serve": "node scripts/serve.js",
    "run:jar": "node scripts/runJar.js",
    "build:java": "node scripts/compileJava.js sources/*.java --out sources",
    "build:bundle": "node scripts/generate-jre-index && webpack --mode production",
    "generate": "npm run build:java && node scripts/generateData.js",
    "build": "npm run generate && npm run build:bundle && node scripts/buildSite.js",
    "clean": "find sources -name '*.class' -delete && rm -rf dist",
    "pretest": "node scripts/generate-jre-index.js &&npm run build:java",
    "ci": "npm run build && npm test",
    "health-check": "node scripts/health-check.js",
    "lint:jasmin": "node scripts/jvm-cli.js lint",
    "cfr": "node scripts/runCfr.js",
    "compile:java": "node scripts/compileJava.js",
    "test:cfr": "node node_modules/tape/bin/tape test/cfrIntegration.test.js test/cfrFixtures.test.js test/cfrStructuredFeatures.test.js test/cfrAdditionalFeatures.test.js test/cfrStackOrdering.test.js test/cfrObfuscationGuards.test.js",
    "test:krakatau-decompiler": "node scripts/run-krakatau-decompiler-tests.js",
    "test:java-frontend": "node node_modules/tape/bin/tape test/javaFrontendAst.test.js test/javaFrontendPassManager.test.js test/javaFrontendCfg.test.js test/javaFrontendCfgJoinStubs.test.js test/javaFrontendExpectedPassStubs.test.js test/javaFrontendIr.test.js test/javaFrontendHelloWorldCompile.test.js test/javaFrontendAllJavaCompile.test.js"
  },
  "keywords": [],
  "author": "kreijstal",
  "license": "AGPLv3",
  "description": "Java bytecode analysis and JVM implementation tools",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.21.1",
    "crc-32": "^1.2.2",
    "decimal.js": "^10.4.3",
    "diff": "^9.0.0",
    "jpeg-js": "^0.4.4",
    "jszip": "^3.10.1",
    "jvm_parser": "^0.0.13",
    "node-fetch": "^3.0.0",
    "parsimmon": "^1.18.1",
    "puppeteer": "^24.17.0",
    "url": "^0.11.4",
    "yargs": "^17.7.2"
  },
  "optionalDependencies": {
    "speaker": "^0.5.5"
  },
  "devDependencies": {
    "@babel/core": "^7.28.0",
    "@babel/preset-env": "^7.28.0",
    "@playwright/test": "^1.45.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "ace-builds": "^1.43.2",
    "babel-loader": "^10.0.0",
    "blessed": "^0.1.81",
    "buffer": "^6.0.3",
    "jsdom": "^26.1.0",
    "path-browserify": "^1.0.1",
    "playwright": "^1.45.0",
    "process": "^0.11.10",
    "stream-browserify": "^3.0.0",
    "tape": "^5.9.0",
    "util": "^0.12.5",
    "webpack": "^5.101.0",
    "webpack-cli": "^7.0.0"
  }
}
